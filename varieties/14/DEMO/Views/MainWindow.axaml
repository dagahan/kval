<!-- Вариант 14 -->
<Window x:Class="DEMO.Views.MainWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:DEMO.ViewModels"
        mc:Ignorable="d"
        d:DesignHeight="450"
        d:DesignWidth="800"
        x:DataType="vm:MainWindowViewModel"
        Title="Валидация данных"
        Icon="/Assets/avalonia-logo.ico">

    <!-- Макет и тексты сохранены без изменения поведения -->
    <Grid ColumnDefinitions="*, *" RowDefinitions="*, *">
        <Button Content="Получить данные"
                Grid.Row="0"
                Grid.Column="0"
                Command="{Binding GetFioCommand}"
                Margin="10"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center"
                HorizontalContentAlignment="Center"/>

        <Button Content="Отправить результат теста"
                Grid.Row="1"
                Grid.Column="0"
                Command="{Binding SendTestResultCommand}"
                Margin="10"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center"
                HorizontalContentAlignment="Center"/>

        <TextBlock Text="{Binding FIO}"
                   Grid.Row="0"
                   Grid.Column="1"
                   Margin="10"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"/>

        <TextBlock Text="{Binding Result}"
                   Grid.Row="1"
                   Grid.Column="1"
                   Margin="10"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"/>
    </Grid>
</Window>
