<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DEMO.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="DEMO.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Валидация данных">

        <Grid RowDefinitions="*, *" ColumnDefinitions="*, *">
                <Button Grid.Column="0" Grid.Row="0" Content="Получить данные"
                        Command="{Binding GetFioCommand}"
                        HorizontalContentAlignment="Center"
                        VerticalAlignment="Center" HorizontalAlignment="Stretch" Margin="10"/>
                <Button Grid.Column="0" Grid.Row="1" Content="Отправить результат теста"
                        Command="{Binding SendTestResultCommand}"
                        HorizontalContentAlignment="Center"
                        VerticalAlignment="Center" HorizontalAlignment="Stretch" Margin="10"/>

                <TextBlock Grid.Column="1" Grid.Row="0" Text="{Binding FIO}"
                           VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10"/>
                <TextBlock Grid.Column="1" Grid.Row="1" Text="{Binding Result}"
                           VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10"/>
        </Grid>
</Window>
